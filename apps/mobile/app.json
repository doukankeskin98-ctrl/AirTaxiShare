{
  "expo": {
    "name": "AirTaxiShare",
    "slug": "air-taxi-share",
    "scheme": "airtaxishare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0D17"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.airtaxishare.mobile",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AirTaxiShare needs your location to find nearby passengers for matching at the airport.",
        "NSCameraUsageDescription": "AirTaxiShare needs access to your camera to scan meeting point QR codes or set your profile picture.",
        "NSPhotoLibraryUsageDescription": "AirTaxiShare needs access to your photo library to let you upload a profile picture.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0D17"
      },
      "package": "com.airtaxishare.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AirTaxiShare to use your location."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4F46E5",
          "sounds": []
        }
      ],
      [
        "expo-apple-authentication"
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "82508bdf-5588-4301-a4f6-a0cdd84aeab2"
      }
    }
  }
}